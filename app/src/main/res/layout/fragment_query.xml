<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/queryEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:text="select * from events" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/dateconversionEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="2026-05-06"
                android:inputType="text" />
            <Button
                android:id="@+id/convertDateBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Convert" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/equel_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="=" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/open_parenthesis_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="(" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/close_parenthesis_btn" android:layout_width="40dp" android:layout_height="40dp" android:text=")" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/Lessthansign" android:layout_width="40dp" android:layout_height="40dp" android:text="&lt;" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/greaterthan_btn" android:layout_width="40dp" android:layout_height="40dp" android:text=">" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/Apostrophe_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="'" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/Percent_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="%" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/underscore_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="_" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/plus_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/minus_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="-" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/Asterisk_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="*" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/slesh_btn" android:layout_width="40dp" android:layout_height="40dp" android:text="/" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
            <Button android:id="@+id/past_btn" android:layout_width="60dp" android:layout_height="40dp" android:text="Paste" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/selectquery_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select" />
            <Button
                android:id="@+id/insertquery_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Insert/Update" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/prequery_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Prev" />
            <Button
                android:id="@+id/nextquery_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Next" />
            <Button
                android:id="@+id/savequery_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save" />
            <Button
                android:id="@+id/removequery_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Remo" />
        </LinearLayout>

        <TextView
            android:id="@+id/columview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Columns"
            android:textIsSelectable="true"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/savedquery"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:nestedScrollingEnabled="true" />

    </LinearLayout>
</ScrollView>
